{
    # Global options block
    auto_https off
    local_certs
}

# SearXNG reverse proxy
localhost {
    reverse_proxy 127.0.0.1:8080 {
        header_up Host {host}
        header_up X-Real-IP {remote}
        header_up X-Forwarded-For {remote}
        header_up X-Forwarded-Proto {scheme}
    }
}
