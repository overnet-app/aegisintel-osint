# App
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

# Database
DATABASE_URL="postgresql://aegis:aegis_password@localhost:5432/aegis_intel?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Elasticsearch
ELASTICSEARCH_NODE=http://localhost:9200

# MinIO
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin_password
MINIO_BUCKET=aegis-intel

# Auth
JWT_SECRET=super_secret_jwt_key_change_me
JWT_EXPIRATION=15m
REFRESH_TOKEN_SECRET=another_secret_key_change_me
REFRESH_TOKEN_EXPIRATION=7d

# AI Providers (Get keys from OpenRouter, Google Cloud, Clarifai, TinEye)
OPENROUTER_API_KEY=
GOOGLE_VISION_API_KEY=
CLARIFAI_API_KEY=
TINEYE_API_KEY=

# Scraper
BROWSER_POOL_SIZE=5
PROXY_URL=
